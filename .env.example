# .env.example
# Nunca comite seu .env real!

DISCORD_TOKEN=COLE_SEU_TOKEN_AQUI

# Opcional
COMMAND_PREFIX=!
# Intervalo entre varreduras em minutos. 720 = 12h. Ex.: 30 = 30 min
LOOP_MINUTES=720
LOG_LEVEL=INFO
HTTP_TIMEOUT=10
# Teto (s) para first_request_delay_sec em sources.json — precisa cobrir delays longos (ex.: Nyaa 60s)
FEED_FIRST_DELAY_MAX_SEC=120
# 1/true = mantém fallbacks rsshub.app em feed_url_fallbacks (default: remove)
# ALLOW_RSSHUB_FALLBACK=
# Entre tentativas 1→2 e 2→3 em falhas transitórias de feed (conexão, timeout, 5xx)
FEED_FETCH_INTER_RETRY_DELAYS=2,5

# Segurança do Servidor Web
# WEB_AUTH_TOKEN: Token para autenticação no servidor web (recomendado para produção)
# WEB_HOST: Host do servidor web (127.0.0.1 = apenas localhost, 0.0.0.0 = todos os IPs)
# WEB_PORT: Porta do servidor web
WEB_AUTH_TOKEN=
WEB_HOST=127.0.0.1
WEB_PORT=8080
