# =============================================================================
# .env.example — copie para .env e preencha. Nunca comite o .env real.
# =============================================================================

# --- Obrigatório ---

DISCORD_TOKEN=COLE_SEU_TOKEN_DO_BOT_AQUI

# O canal de notícias NÃO vem deste arquivo: use /set_canal no Discord ou config.json.
# (DISCORD_CHANNEL_ID não é lido pelo bot.)

# --- Operação geral ---

COMMAND_PREFIX=!
# Intervalo entre varreduras em minutos (1–1440). Ex.: 30 = 30 min, 240 = 4 h, 720 = 12 h
LOOP_MINUTES=720

# INFO | DEBUG | WARNING | ERROR
LOG_LEVEL=INFO

# 1 / true / yes / on = logs detalhados da varredura (SEMAFORO, JITTER, PROXY, CACHE…) em INFO
# sem precisar de LOG_LEVEL=DEBUG no servidor/Docker
SCAN_VERBOSE=0

# --- HTTP / feeds RSS ---

HTTP_TIMEOUT=10
FEED_FETCH_MAX_ATTEMPTS=3
FEED_FETCH_RETRY_BACKOFF_SEC=2.0
# Pausas (s) entre tentativas após falha transitória — formato CSV, ex.: 2,5 ou 2,5,8
FEED_FETCH_INTER_RETRY_DELAYS=2,5

# Teto (s) para http_timeout_sec por feed em sources.json → feed_fetch_overrides
FEED_HTTP_TIMEOUT_MAX_SEC=120
# Teto (s) para first_request_delay_sec em feed_fetch_overrides
FEED_FIRST_DELAY_MAX_SEC=120

# Quantos feeds buscar ao mesmo tempo (1–10). Menos = menos bloqueio por IP
MAX_CONCURRENT_FEEDS=3

# Jitter aleatório (s) antes de cada GET — reduz padrão robótico
FEED_FETCH_JITTER_MIN=0.5
FEED_FETCH_JITTER_MAX=2.5

# Opcional: User-Agent dos pedidos RSS/Atom (identificável)
# FEED_USER_AGENT=MaftyIntelBot/1.0 (+https://github.com/carmipa/gundam-news-discord)

# Opcional: Worker Cloudflare para roteamento — URL base com ?url= no final, se usar
# CLOUDFLARE_PROXY_URL=https://seu-worker.workers.dev/?url=

# --- Servidor web (dashboard) ---

# Token forte em produção (não use um carácter só)
WEB_AUTH_TOKEN=
# Em Docker com `ports` publicados, use 0.0.0.0 para o bind aceitar o encaminhamento do host
WEB_HOST=127.0.0.1
WEB_PORT=8080
# Porta no *host* (VPS) — docker-compose mapeia HOST_WEB_PORT -> WEB_PORT. Se der "port is already allocated", use outra (ex.: 8081)
HOST_WEB_PORT=8080
